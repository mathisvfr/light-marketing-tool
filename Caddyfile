{$DOMAIN} {
  encode zstd gzip

  @api path /api/*
  reverse_proxy @api backend:3001

  @feeds path /feeds/*
  reverse_proxy @feeds backend:3001

  @uploads path /uploads/*
  reverse_proxy @uploads backend:3001

  reverse_proxy frontend:80
}

{$FEED_DOMAIN} {
  encode zstd gzip

  # Feed-subdomein serveert uitsluitend de XML-feed; al het andere is 404.
  @feeds path /feeds/*
  reverse_proxy @feeds backend:3001

  respond 404
}

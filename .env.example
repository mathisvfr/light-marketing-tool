# App
NODE_ENV=production
PORT=3001
CORS_ORIGIN=
JWT_SECRET=
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
# Sleutel voor het versleutelen van integratie-credentials (Buffer/WordPress) in de database.
# Genereer bijv. met: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AI provider (anthropic|gemini|greenpt)
AI_PROVIDER=gemini

# Google AI Studio (Gemini)
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# GreenPT (OpenAI-compatible API)
GREENPT_API_KEY=
GREENPT_MODEL=green-r-raw
GREENPT_API_URL=https://api.greenpt.ai/v1

# Buffer (Type B: LinkedIn, Facebook, Instagram)
BUFFER_API_KEY=
BUFFER_LINKEDIN_CHANNEL_ID=
BUFFER_FACEBOOK_CHANNEL_ID=
BUFFER_INSTAGRAM_CHANNEL_ID=
BUFFER_API_URL=https://api.buffer.com
BUFFER_DEFAULT_IMAGE_URL=

# WordPress
WORDPRESS_URL=
WORDPRESS_API_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# Notificaties (optioneel; standaard uit). Gebruikt door de SEO-publicatieflow.
NOTIFICATIONS_ENABLED=
NOTIFICATION_TRANSPORT=

# Domein (Caddy)
DOMAIN=
FEED_DOMAIN=feed.lightpersoneelsdiensten.nl

# Optioneel (publieke basis-URL voor afbeeldingslinks)
APP_BASE_URL=
PUBLIC_APP_URL=

# Optioneel: beveilig XML feed met Basic Auth voor Multiposter
FEEDS_BASIC_AUTH_USERNAME=
FEEDS_BASIC_AUTH_PASSWORD=
